{
  "name": "shift-mcp-server",
  "version": "0.1.2",
  "description": "Lightweight coordination layer for multiple AI agents working on the same codebase simultaneously.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "shift-mcp-server": "dist/index.js"
  },
  "files": ["dist/", "README.md", "LICENSE", "CLAUDE.md", "Dockerfile", "server.json"],
  "scripts": {
    "build": "bun scripts/build.ts",
    "rebuild": "bun scripts/clean.ts && bun scripts/build.ts",
    "clean": "bun scripts/clean.ts",
    "devcheck": "bun scripts/devcheck.ts",
    "tree": "bun scripts/tree.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "bun scripts/lint-mcp.ts",
    "test": "vitest run",
    "dev:stdio": "MCP_TRANSPORT_TYPE=stdio bun --watch src/index.ts",
    "dev:http": "MCP_TRANSPORT_TYPE=http bun --watch src/index.ts",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "multi-agent",
    "coordination",
    "ai-agents",
    "agent-coordination",
    "claude-code",
    "typescript"
  ],
  "mcpName": "io.github.cyanheads/shift-mcp-server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/shift-mcp-server.git"
  },
  "homepage": "https://github.com/cyanheads/shift-mcp-server",
  "bugs": {
    "url": "https://github.com/cyanheads/shift-mcp-server/issues"
  },
  "author": "Casey Hand (https://github.com/cyanheads)",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0",
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.2",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^0.1.25",
    "depcheck": "^1.4.7",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
